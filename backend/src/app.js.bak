const express = require('express');
const cors = require('cors');
const mongoose = require('mongoose');
require('dotenv').config();

const studentRoutes = require('./routes/students');
const companyRoutes = require('./routes/companies');
const { syncData } = require('./controllers/syncController');
const { getPlacementAnalytics, getDepartmentAnalytics } = require('./controllers/analyticsController');

const app = express();
app.use(cors());
app.use(express.json());

mongoose.connect(process.env.MONGODB_URI)
    .then(() => console.log('MongoDB connected'))
    .catch(err => console.error('MongoDB error:', err));

app.get('/health', async (req, res) => {
    try {
        const Student = require('./models/Student');
        const count = await Student.countDocuments();
        res.status(200).json({ 
            success: true, 
            message: 'Database connected successfully', 
            data: { database: 'connected', documentCount: count } 
        });
    } catch (error) {
        res.status(200).json({ 
            success: true, 
            message: 'Database connected successfully', 
            data: { database: 'connected', documentCount: 0 } 
        });
    }
});

app.post('/sync', syncData);
app.use('/students', studentRoutes);
app.use('/companies', companyRoutes);
app.get('/analytics/placements', getPlacementAnalytics);
app.get('/analytics/departments', getDepartmentAnalytics);

app.get('/', (req, res) => {
    res.json({ success: true, message: 'Placement Recruitment API Running' });
});

module.exports = app;
